# ===================================================================
# Lombok Configuration for JaCoCo Coverage
# ===================================================================
# This configuration adds @Generated annotation to all Lombok-generated code
# so that JaCoCo and SonarQube ignore it during coverage analysis.
#
# Place this file in the root of your project (parent module).
# Lombok will automatically detect and apply this configuration.
# ===================================================================

# Add @lombok.Generated to all Lombok-generated code
lombok.addLombokGeneratedAnnotation = true

# Optional: Configure Lombok features
config.stopBubbling = true
